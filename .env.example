# Quantum Nexus Forge — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The system runs in MOCK mode by default — no Azure needed for development.

# ── AI Mode ──────────────────────────────────
# Set to false to enable live Azure OpenAI responses
MOCK_AI=true

# ── Azure OpenAI ─────────────────────────────
# Required only when MOCK_AI=false
AOAI_ENDPOINT=https://your-resource.openai.azure.com/
AOAI_API_KEY=your-azure-openai-api-key
AOAI_DEPLOYMENT=gpt-4o

# ── Azure Cosmos DB ──────────────────────────
# Required only for persistent conversation storage
# Leave empty to use in-memory storage (data resets on restart)
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-db-key
COSMOS_DATABASE=quantum-nexus
COSMOS_CONTAINER=conversations

# ── API Security ─────────────────────────────
# Optional: protects the API endpoints with a key header
API_KEY=

# ── Server ───────────────────────────────────
PORT=5000
HOST=127.0.0.1
